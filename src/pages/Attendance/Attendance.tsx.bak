import { useState, useEffect, useRef } from 'react';
import { useApp } from '../../store/AppContext';
import { Mic, MicOff, SkipForward, SkipBack } from 'lucide-react';
import type { AttendanceStatus } from '../../types';

const statusConfig: Record<AttendanceStatus, { label: string; color: string; bgColor: string }> = {
  presente: { label: 'Presente', color: 'var(--success)', bgColor: 'rgba(34, 197, 94, 0.2)' },
  ausente: { label: 'Ausente', color: 'var(--danger)', bgColor: 'rgba(220, 38, 38, 0.2)' },
  ausencia_justificada: { label: 'Justificada', color: 'var(--accent-primary)', bgColor: 'rgba(37, 99, 235, 0.2)' },
  retraso_justificado: { label: 'Retraso', color: 'var(--warning)', bgColor: 'rgba(245, 158, 11, 0.2)' },
  expulsado: { label: 'Expulsado', color: '#9333ea', bgColor: 'rgba(147, 51, 234, 0.2)' },
};

export const Attendance = () => {
  const { state, setAttendance, getAttendanceByDateAndClass, getStudentsByClass } = useApp();
  const [selectedClassId, setSelectedClassId] = useState(state.classes[0]?.id || '');
  const [selectedDate, setSelectedDate] = useState(new Date().toISOString().split('T')[0]);
  const [callingMode, setCallingMode] = useState(false);
  const [currentIndex, setCurrentIndex] = useState(0);
  const [studentComments, setStudentComments] = useState<Record<string, string>>({});
  const [pendingStatus, setPendingStatus] = useState<{studentId: string; status: AttendanceStatus} | null>(null);
  const studentRefs = useRef<(HTMLDivElement | null)[]>([]);

  const students = selectedClassId ? getStudentsByClass(selectedClassId) : [];
  const attendances = getAttendanceByDateAndClass(selectedDate, selectedClassId);
  const selectedClass = state.classes.find(c => c.id === selectedClassId);

  const needsComment = (status: AttendanceStatus) => {
    return status === 'ausencia_justificada' || status === 'retraso_justificado' || status === 'expulsado';
  };

  useEffect(() => {
    if (callingMode && studentRefs.current[currentIndex] && !pendingStatus) {
      studentRefs.current[currentIndex]?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }, [callingMode, currentIndex, pendingStatus]);

  const getAttendance = (studentId: string) => {
    return attendances.find(a => a.studentId === studentId);
  };

  const handleStatusChange = (studentId: string, status: AttendanceStatus) => {
    if (needsComment(status) {
      setPendingStatus({ studentId, status });
    } else {
      submitAttendance(studentId, status);
    }
  };

  const submitAttendance = (studentId: string, status: AttendanceStatus, comment?: string) => {
    setAttendance({
      classId: selectedClassId,
      studentId,
      date: selectedDate,
      status,
      comment,
    });
    setPendingStatus(null);

    if (callingMode && currentIndex < students.length - 1) {
      setTimeout(() => {
        setCurrentIndex(prev => prev + 1);
      }, 300);
    } else if (callingMode && currentIndex === students.length - 1) {
      setCallingMode(false);
    }
  };

  const handleConfirmWithComment = () => {
    if (pendingStatus) {
      const comment = studentComments[pendingStatus.studentId]?.trim();
      submitAttendance(pendingStatus.studentId, pendingStatus.status, comment || undefined);
    }
  };

  const getMonthlyStats = () => {
    const currentMonth = new Date().toISOString().slice(0, 7);
    const monthAttendances = state.attendance.filter(
      a => a.date.startsWith(currentMonth) && a.classId === selectedClassId
    );
    
    const stats: Record<AttendanceStatus, number> = {
      presente: 0,
      ausente: 0,
      ausencia_justificada: 0,
      retraso_justificado: 0,
      expulsado: 0,
    };

    monthAttendances.forEach(a => {
      stats[a.status]++;
    });

    return stats;
  };

  const monthlyStats = selectedClassId ? getMonthlyStats() : null;

  const formatDate = (dateStr: string) => {
    const date = new Date(dateStr + 'T00:00:00');
    return date.toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' });
  };

  return (
    <div style={{ display: 'flex', flexDirection: 'column', gap: '24px' }}>
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', flexWrap: 'wrap', gap: '16px' }}>
        <div>
          <h1 style={{ fontSize: '24px', fontWeight: 'bold', color: 'var(--text-primary)', marginBottom: '4px' }}>Asistencia</h1>
          <p style={{ color: 'var(--text-muted)' }}>Control de asistencia diaria</p>
        </div>
        {students.length > 0 && (
          <button
            onClick={() => {
              if (callingMode) {
                setCallingMode(false);
              } else {
                setCurrentIndex(0);
              }
              setCallingMode(!callingMode);
            }}
            style={{
              display: 'flex',
              alignItems: 'center',
              gap: '8px',
              padding: '12px 20px',
              borderRadius: '12px',
              border: 'none',
              background: callingMode ? 'var(--danger)' : 'var(--success)',
              color: 'white',
              fontWeight: '600',
              cursor: 'pointer',
            }}
          >
            {callingMode ? <><MicOff size={20} /> Detener</> : <><Mic size={20} /> Llamar Lista</>}
          </button>
        )}
      </div>

      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))', gap: '16px' }}>
        <div style={{ background: 'var(--bg-secondary)', borderRadius: '12px', padding: '16px', border: '1px solid var(--border-color)' }}>
          <label style={{ display: 'block', fontSize: '14px', fontWeight: '500', color: 'var(--text-secondary)', marginBottom: '8px' }}>Clase</label>
          <select
            value={selectedClassId}
            onChange={(e) => setSelectedClassId(e.target.value)}
            style={{ width: '100%', padding: '12px 16px', borderRadius: '12px', border: '1px solid var(--border-color)', fontSize: '16px', background: 'var(--bg-secondary)', color: 'var(--text-primary)' }}
          >
            {state.classes.map(cls => (
              <option key={cls.id} value={cls.id}>{cls.name}</option>
            ))}
          </select>
        </div>

        <div style={{ background: 'var(--bg-secondary)', borderRadius: '12px', padding: '16px', border: '1px solid var(--border-color)' }}>
          <label style={{ display: 'block', fontSize: '14px', fontWeight: '500', color: 'var(--text-secondary)', marginBottom: '8px' }}>Fecha</label>
          <input
            type="date"
            value={selectedDate}
            onChange={(e) => setSelectedDate(e.target.value)}
            style={{ width: '100%', padding: '12px 16px', borderRadius: '12px', border: '1px solid var(--border-color)', fontSize: '16px', background: 'var(--bg-secondary)', color: 'var(--text-primary)' }}
          />
        </div>

        <div style={{ background: 'var(--bg-secondary)', borderRadius: '12px', padding: '16px', border: '1px solid var(--border-color)', display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
          <p style={{ color: 'var(--text-secondary)' }}>{formatDate(selectedDate)}</p>
        </div>
      </div>

      {callingMode && students.length > 0 && (
        <div style={{ background: 'linear-gradient(to right, var(--accent-primary), var(--accent-hover))', borderRadius: '12px', padding: '16px', color: 'white' }}>
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', flexWrap: 'wrap', gap: '16px', marginBottom: '12px' }}>
            <div style={{ display: 'flex', alignItems: 'center', gap: '12px' }}>
              <button
                onClick={() => setCurrentIndex(Math.max(0, currentIndex - 1))}
                disabled={currentIndex === 0}
                style={{ padding: '8px', background: 'rgba(255,255,255,0.2)', borderRadius: '8px', border: 'none', color: 'white', cursor: currentIndex === 0 ? 'not-allowed' : 'pointer', opacity: currentIndex === 0 ? 0.5 : 1 }}
              >
                <SkipBack size={20} />
              </button>
              <div>
                <p style={{ fontSize: '14px', opacity: 0.8 }}>Estudiante {currentIndex + 1} de {students.length}</p>
                <p style={{ fontWeight: '600', fontSize: '18px' }}>{students[currentIndex]?.name} {students[currentIndex]?.lastName}</p>
              </div>
              <button
                onClick={() => setCurrentIndex(Math.min(students.length - 1, currentIndex + 1))}
                disabled={currentIndex === students.length - 1}
                style={{ padding: '8px', background: 'rgba(255,255,255,0.2)', borderRadius: '8px', border: 'none', color: 'white', cursor: currentIndex === students.length - 1 ? 'not-allowed' : 'pointer', opacity: currentIndex === students.length - 1 ? 0.5 : 1 }}
              >
                <SkipForward size={20} />
              </button>
            </div>
            <div style={{ display: 'flex', alignItems: 'center', gap: '8px' }}>
              <Mic size={18} />
              <span style={{ fontWeight: '500' }}>Modo Llamar Lista</span>
            </div>
          </div>
          
          <div style={{ display: 'flex', gap: '8px', flexWrap: 'wrap', justifyContent: 'center' }}>
            {Object.entries(statusConfig).map(([status, config]) => (
              <button
                key={status}
                onClick={() => students[currentIndex] && handleStatusChange(students[currentIndex].id, status as AttendanceStatus)}
                disabled={!!pendingStatus}
                style={{
                  padding: '10px 14px',
                  borderRadius: '8px',
                  border: 'none',
                  fontSize: '13px',
                  fontWeight: '600',
                  cursor: pendingStatus ? 'not-allowed' : 'pointer',
                  background: 'rgba(255,255,255,0.25)',
                  color: 'white',
                  opacity: pendingStatus ? 0.5 : 1,
                }}
              >
                {config.label}
              </button>
            ))}
          </div>
          
          {pendingStatus && (
            <div style={{ background: 'white', borderRadius: '12px', padding: '16px', marginTop: '12px' }}>
              <p style={{ fontSize: '14px', fontWeight: '600', color: 'var(--text-primary)', marginBottom: '8px' }}>
                Agregar motivo para  {statusConfig[pendingStatus.status].label}:
              </p>
              <input
                type="text"
                value={studentComments[pendingStatus.studentId] || ''}
                onChange={(e) => setStudentComments(prev => ({ ...prev, [pendingStatus.studentId]: e.target.value }))}
                placeholder="Escribe el motivo o descripción..."
                style={{ width: '100%', padding: '12px', borderRadius: '8px', border: '1px solid var(--border-color)', fontSize: '14px', background: 'var(--bg-secondary)', color: 'var(--text-primary)', marginBottom: '12px' }}
              />
              <div style={{ display: 'flex', gap: '8px' }}>
                <button
                  onClick={() => {
                    setPendingStatus(null);
                    setStudentComments(prev => ({ ...prev, [pendingStatus.studentId]: '' }));
                  }}
                  style={{ flex: 1, padding: '10px', borderRadius: '8px', border: '1px solid var(--border-color)', background: 'var(--bg-secondary)', color: 'var(--text-secondary)', cursor: 'pointer', fontWeight: '500' }}
                >
                  Cancelar
                </button>
                <button
                  onClick={handleConfirmWithComment}
                  style={{ flex: 1, padding: '10px', borderRadius: '8px', border: 'none', background: 'var(--accent-primary)', color: 'white', cursor: 'pointer', fontWeight: '600' }}
                >
                  Confirmar
                </button>
              </div>
            </div>
          )}
          
          </div>
      )}

      {selectedClassId && (
        <div style={{ display: 'flex', flexDirection: 'column', gap: '12px' }}>
          {students.map((student, index) => {
            const attendance = getAttendance(student.id);
            const isCurrent = callingMode && currentIndex === index;

            return (
              <div
                key={student.id}
                ref={(el) => { studentRefs.current[index] = el; }}
                style={{
                  background: 'var(--bg-secondary)',
                  borderRadius: '12px',
                  padding: '16px',
                  border: isCurrent ? '2px solid var(--accent-primary)' : '1px solid var(--border-color)',
                  boxShadow: isCurrent ? '0 0 0 4px rgba(37, 99, 235, 0.1)' : 'none',
                }}
              >
                <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', flexWrap: 'wrap', gap: '12px' }}>
                  <div style={{ display: 'flex', alignItems: 'center', gap: '12px' }}>
                    <div style={{ width: '40px', height: '40px', borderRadius: '50%', display: 'flex', alignItems: 'center', justifyContent: 'center', fontWeight: '600', background: isCurrent ? 'var(--accent-primary)' : 'var(--bg-tertiary)', color: isCurrent ? 'white' : 'var(--text-secondary)' }}>
                      {index + 1}
                    </div>
                    <div>
                      <p style={{ fontWeight: '600', color: 'var(--text-primary)' }}>{student.name} {student.lastName}</p>
                      {attendance && (
                        <p style={{ fontSize: '14px', color: statusConfig[attendance.status].color }}>
                          {statusConfig[attendance.status].label}
                          {attendance.comment && ` - ${attendance.comment}`}
                        </p>
                      )}
                    </div>
                  </div>

                  <div style={{ display: 'flex', flexWrap: 'wrap', gap: '6px' }}>
                    {Object.entries(statusConfig).map(([status, config]) => (
                      <button
                        key={status}
                        onClick={() => handleStatusChange(student.id, status as AttendanceStatus)}
                        style={{
                          padding: '6px 10px',
                          borderRadius: '6px',
                          border: 'none',
                          fontSize: '12px',
                          fontWeight: '500',
                          cursor: 'pointer',
                          background: attendance?.status === status ? config.bgColor : 'var(--bg-tertiary)',
                          color: attendance?.status === status ? config.color : 'var(--text-secondary)',
                        }}
                      >
                        {config.label}
                      </button>
                    ))}
                  </div>
                </div>

                {(attendance?.status === 'ausencia_justificada' || attendance?.status === 'retraso_justificado' || attendance?.status === 'expulsado') && (
                  <div style={{ marginTop: '12px', paddingTop: '12px', borderTop: '1px solid var(--border-color)' }}>
                    <input
                      type="text"
                      value={studentComments[student.id] || ''}
                      onChange={(e) => setStudentComments(prev => ({ ...prev, [student.id]: e.target.value }))}
                      placeholder="Agregar comentario (motivo, detalles, etc.)..."
                      style={{ width: '100%', padding: '10px 12px', borderRadius: '8px', border: '1px solid var(--border-color)', fontSize: '14px', background: 'var(--bg-tertiary)', color: 'var(--text-primary)' }}
                    />
                  </div>
                )}
              </div>
            );
          })}
        </div>
      )}

      {monthlyStats && (
        <div style={{ background: 'var(--bg-secondary)', borderRadius: '12px', padding: '24px', border: '1px solid var(--border-color)' }}>
          <h2 style={{ fontSize: '18px', fontWeight: '600', color: 'var(--text-primary)', marginBottom: '16px' }}>
            Resumen Mensual - {selectedClass?.name}
          </h2>
          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(140px, 1fr))', gap: '12px' }}>
            {Object.entries(statusConfig).map(([status, config]) => (
              <div key={status} style={{ padding: '16px', borderRadius: '12px', background: config.bgColor }}>
                <p style={{ fontSize: '24px', fontWeight: 'bold', color: config.color }}>
                  {monthlyStats[status as AttendanceStatus]}
                </p>
                <p style={{ fontSize: '14px', color: config.color }}>{config.label}</p>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
};
